{
  "name": "portfolio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && gh-pages -d dist",
    "lint": "eslint src/ && stylelint 'src/**/*.scss'",
    "lint:fix": "eslint src/ --fix && stylelint 'src/**/*.scss' --fix",
    "format": "prettier --write 'src/**/*.{ts,scss}' '*.{json,html,md}'",
    "format:check": "prettier --check 'src/**/*.{ts,scss}' '*.{json,html,md}'",
    "check": "npm run format:check && npm run lint && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "gh-pages": "^6.3.0",
    "prettier": "^3.8.1",
    "sass": "^1.83.0",
    "stylelint": "^17.4.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.0.0"
  }
}
